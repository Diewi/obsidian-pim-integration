{
	"name": "obsidian-pim-integration",
	"version": "0.1.0",
	"description": "Integration for MS office or groupware (e.g. CardDav)",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "jest --watch",
		"proto:generate": "node node_modules/protobufjs-cli/bin/pbjs -t static-module -w commonjs -o src_generated/native_bridge.js src_native/proto/native_bridge.proto && node node_modules/protobufjs-cli/bin/pbts -o src_generated/native_bridge.d.ts src_generated/native_bridge.js"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@agracio/edge-cs": "^1.3.7",
		"@date-fns/utc": "^2.1.1",
		"@popperjs/core": "^2.11.6",
		"@types/jest": "^30.0.0",
		"@types/lodash": "^4.17.10",
		"@types/node": "^24.3.3",
		"@types/underscore": "^1.11.15",
		"@types/vcf": "^2.0.7",
		"@typescript-eslint/eslint-plugin": "^8.43.0",
		"@typescript-eslint/parser": "^8.43.0",
		"builtin-modules": "^5.0.0",
		"date-fns": "^4.1.0",
		"electron-edge-js": "^38.0.0",
		"esbuild": "^0.25.4",
		"esbuild-plugin-copy": "^2.1.1",
		"fp-ts": "^2.16.9",
		"ical.js": "^2.2.1",
		"jest": "^30.1.3",
		"obsidian": "^1.8.7",
		"oxide.ts": "^1.1.0",
		"protobufjs": "^7.5.4",
		"ts-jest": "^29.2.5",
		"tslib": "^2.8.1",
		"typed-vCard": "file:../typed-vcard",
		"typescript": "^5.9.3",
		"vcf": "^2.1.2",
		"workerpool": "^10.0.1"
	},
	"devDependencies": {
		"edge-js": "^25.0.0",
		"eslint": "^9.39.3",
		"license-checker": "^25.0.1",
		"prettier": "^3.8.1",
		"protobufjs-cli": "^2.0.0"
	}
}
