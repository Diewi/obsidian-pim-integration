{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "OutlookComBridge: dotnet build debug",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/OutlookComBridge.sln",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "OutlookComBridge: dotnet build release",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/OutlookComBridge.sln",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign",
				"--configuration=Release"
			],
			"problemMatcher": "$msCompile"
		}
	]
}
